# ============================================================================
# Variáveis do app — copie este arquivo para ".env" e preencha (para CLONAR).
# ----------------------------------------------------------------------------
# Se deixar em branco / não criar o .env, o app usa o Supabase PADRÃO (o original).
# Para um app NOVO (clone), aponte para o SEU Supabase novo. Veja docs/NOVO-APP.md.
# ============================================================================

# URL do seu projeto Supabase (Supabase → Project Settings → Data API → Project URL)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave pública "anon" (Supabase → Project Settings → API Keys → anon public)
VITE_SUPABASE_ANON_KEY=cole-sua-anon-key-aqui
